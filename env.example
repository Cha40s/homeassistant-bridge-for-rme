# /etc/default/rme-mqtt-bridge
# MQTT credentials (shared by rme-mqtt-bridge and raspotify-manager)
MQTT_USER=mqtt
MQTT_PASS=changeme

# --- Optional: Raspotify (Spotify Connect vom Pi) ---
# Falls der Pi auch als Spotify-Quelle dienen soll:
#   1. sudo apt install raspotify
#   2. sudo cp conf /etc/raspotify/conf
#   3. sudo systemctl enable --now raspotify raspotify-manager
