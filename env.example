# /etc/default/rme-mqtt-bridge
# Shared by rme-mqtt-bridge and raspotify-manager services

# --- MQTT Credentials ---
MQTT_USER=mqtt
MQTT_PASS=changeme

# --- Optional: Override defaults from service file ---
# Uncomment and adjust as needed:
#MQTT_HOST=192.168.100.60
#MQTT_PORT=1883
#MIDI_PORT=hw:1,0,0
#DEFAULT_DB=-50.0
#MIN_DB=-60.0
#MAX_DB=-10.0
#DEBUG=0

# --- Optional: Raspotify (Spotify Connect) ---
# To use the Pi as a Spotify source:
#   1. sudo apt install raspotify
#   2. sudo cp conf /etc/raspotify/conf
#   3. sudo systemctl enable --now raspotify raspotify-manager
